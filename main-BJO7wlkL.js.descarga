    @keyframes dotAnimation {
      0%, 100% { content: ""; }
      25% { content: "."; }
      50% { content: ".."; }
      75% { content: "..."; }
    }
    .animated-dots::after {
      content: "";
      animation: dotAnimation 2s steps(1) infinite;
      display: inline-block;
      width: 15px;
